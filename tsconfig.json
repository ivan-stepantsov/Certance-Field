{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["es2022"],
    "noEmit": true,
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "scripts/**/*.js"
  ]
}